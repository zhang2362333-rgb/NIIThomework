<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Configure Address Bean -->
    <bean id="address" class="com.niit.Address">
        <property name="city" value="Beijing"/>
    </bean>

    <!-- Configure Student Bean - Using Setter Injection -->
    <bean id="student" class="com.niit.Student">
        <!-- Inject basic type value (name) -->
        <property name="name" value="Zhang San"/>
        <!-- Inject another class object (address) -->
        <property name="address" ref="address"/>
    </bean>

</beans>
